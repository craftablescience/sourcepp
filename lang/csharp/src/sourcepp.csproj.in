<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
    <IsTrimmable>True</IsTrimmable>
    <IsAotCompatible>True</IsAotCompatible>
    <TreatWarningsAsErrors>True</TreatWarningsAsErrors>

	<PackageId>${PROJECT_NAME}</PackageId>
    <Title>SourcePP</Title>
    <Description>${PROJECT_DESCRIPTION}</Description>
    <Version>${SOURCEPP_VERSION}</Version>
    <Authors>craftablescience</Authors>
    <Copyright>Copyright (c) 2023 Laura Lewis</Copyright>
    <PackageIcon>logo_128.png</PackageIcon>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageProjectUrl>https://github.com/craftablescience/sourcepp</PackageProjectUrl>
    <RepositoryUrl>https://github.com/craftablescience/sourcepp</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageTags>source;source-engine;file-formats</PackageTags>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
  </PropertyGroup>

  <ItemGroup>
    <None Include="../../../branding/logo_128.png" Pack="True" PackagePath="./" />
    <None Include="../../../LICENSE" Pack="True" PackagePath="./" />
    <None Include="../../../README.md" Pack="True" PackagePath="./" />
    <None Include="../../../THIRDPARTY_LEGAL_NOTICES.txt" Pack="True" PackagePath="./" />
  </ItemGroup>

  <PropertyGroup>
    <IsWindows Condition="'$([System.Runtime.InteropServices.RuntimeInformation]::IsOSPlatform($([System.Runtime.InteropServices.OSPlatform]::Windows)))' == 'True'">True</IsWindows>
    <IsOSX Condition="'$([System.Runtime.InteropServices.RuntimeInformation]::IsOSPlatform($([System.Runtime.InteropServices.OSPlatform]::OSX)))' == 'True'">True</IsOSX>
    <IsLinux Condition="'$([System.Runtime.InteropServices.RuntimeInformation]::IsOSPlatform($([System.Runtime.InteropServices.OSPlatform]::Linux)))' == 'True'">True</IsLinux>
  </PropertyGroup>

  <ItemGroup Condition="$(IsWindows) == 'True'">
    <Content Include="sourcepp_gameppc.dll" Pack="True" PackagePath="runtimes/win-x64/native/">
      <TargetPath>%(Filename)%(Extension)</TargetPath>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>
  <ItemGroup Condition="$(IsOSX) == 'True'">
    <Content Include="sourcepp_gameppc.dylib" Pack="True" PackagePath="runtimes/osx-arm64/native/">
      <TargetPath>%(Filename)%(Extension)</TargetPath>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>
  <ItemGroup Condition="$(IsLinux) == 'True'">
    <Content Include="sourcepp_gameppc.so" Pack="True" PackagePath="runtimes/linux-x64/native/">
      <TargetPath>%(Filename)%(Extension)</TargetPath>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

  <ItemGroup Condition="$(IsWindows) == 'True'">
    <Content Include="sourcepp_sourceppc.dll" Pack="True" PackagePath="runtimes/win-x64/native/">
      <TargetPath>%(Filename)%(Extension)</TargetPath>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>
  <ItemGroup Condition="$(IsOSX) == 'True'">
    <Content Include="sourcepp_sourceppc.dylib" Pack="True" PackagePath="runtimes/osx-arm64/native/">
      <TargetPath>%(Filename)%(Extension)</TargetPath>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>
  <ItemGroup Condition="$(IsLinux) == 'True'">
    <Content Include="sourcepp_sourceppc.so" Pack="True" PackagePath="runtimes/linux-x64/native/">
      <TargetPath>%(Filename)%(Extension)</TargetPath>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

  <ItemGroup Condition="$(IsWindows) == 'True'">
    <Content Include="sourcepp_vcryptppc.dll" Pack="True" PackagePath="runtimes/win-x64/native/">
      <TargetPath>%(Filename)%(Extension)</TargetPath>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>
  <ItemGroup Condition="$(IsOSX) == 'True'">
    <Content Include="sourcepp_vcryptppc.dylib" Pack="True" PackagePath="runtimes/osx-arm64/native/">
      <TargetPath>%(Filename)%(Extension)</TargetPath>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>
  <ItemGroup Condition="$(IsLinux) == 'True'">
    <Content Include="sourcepp_vcryptppc.so" Pack="True" PackagePath="runtimes/linux-x64/native/">
      <TargetPath>%(Filename)%(Extension)</TargetPath>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

  <ItemGroup Condition="$(IsWindows) == 'True'">
    <Content Include="sourcepp_vpkppc.dll" Pack="True" PackagePath="runtimes/win-x64/native/">
      <TargetPath>%(Filename)%(Extension)</TargetPath>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>
  <ItemGroup Condition="$(IsOSX) == 'True'">
    <Content Include="sourcepp_vpkppc.dylib" Pack="True" PackagePath="runtimes/osx-arm64/native/">
      <TargetPath>%(Filename)%(Extension)</TargetPath>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>
  <ItemGroup Condition="$(IsLinux) == 'True'">
    <Content Include="sourcepp_vpkppc.so" Pack="True" PackagePath="runtimes/linux-x64/native/">
      <TargetPath>%(Filename)%(Extension)</TargetPath>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

  <ItemGroup Condition="$(IsWindows) == 'True'">
    <Content Include="sourcepp_vtfppc.dll" Pack="True" PackagePath="runtimes/win-x64/native/">
      <TargetPath>%(Filename)%(Extension)</TargetPath>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>
  <ItemGroup Condition="$(IsOSX) == 'True'">
    <Content Include="sourcepp_vtfppc.dylib" Pack="True" PackagePath="runtimes/osx-arm64/native/">
      <TargetPath>%(Filename)%(Extension)</TargetPath>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>
  <ItemGroup Condition="$(IsLinux) == 'True'">
    <Content Include="sourcepp_vtfppc.so" Pack="True" PackagePath="runtimes/linux-x64/native/">
      <TargetPath>%(Filename)%(Extension)</TargetPath>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

</Project>
